---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import { SITE } from '../../consts';
import {
  getLangFromUrl,
  useTranslations,
  localizePath,
  getStaticLangPaths,
} from '../../i18n/ui';

export const getStaticPaths = getStaticLangPaths;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const c = t.contactPage;
const privacyHref = localizePath('/privacy', lang);

const mailtoHref = `mailto:${SITE.email}?subject=${encodeURIComponent(
  c.mailSubject
)}`;
---

<BaseLayout title={c.pageTitle} description={c.description}>
  <PageHeader eyebrow={c.eyebrow} title={c.headerTitle} lead={c.description} />

  <section class="py-14 sm:py-20">
    <div class="aw-prose-container">
      <div class="rounded-3xl border border-soft-gray bg-white p-7 sm:p-10">
        <h2 class="font-serif text-xl font-bold text-navy">
          {c.emailHeading}
        </h2>
        <p class="mt-3 text-base leading-8 text-charcoal">
          {c.emailBody}
        </p>

        <div
          class="mt-6 flex flex-col gap-4 rounded-2xl bg-background p-5 sm:flex-row sm:items-center sm:justify-between"
        >
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.16em] text-gold">
              {c.emailLabel}
            </p>
            <a
              href={mailtoHref}
              class="mt-1 block break-all font-medium text-navy underline decoration-gold/50 underline-offset-4 hover:decoration-gold"
            >
              {SITE.email}
            </a>
          </div>
          <a href={mailtoHref} class="btn-primary shrink-0">{c.sendButton}</a>
        </div>

        <div class="mt-8">
          <h3 class="text-sm font-bold text-navy">{c.topicsHeading}</h3>
          <ul class="mt-3 space-y-2">
            {
              c.topics.map((topic) => (
                <li class="flex items-start gap-2.5 text-sm leading-7 text-charcoal">
                  <span class="mt-2.5 h-1.5 w-1.5 shrink-0 rounded-full bg-gold" aria-hidden="true" />
                  {topic}
                </li>
              ))
            }
          </ul>
        </div>

        <p class="mt-8 text-xs leading-6 text-charcoal/60">
          {c.noteBefore}
          <a
            href={privacyHref}
            class="underline decoration-gold/50 underline-offset-2 hover:decoration-gold"
            >{c.noteLink}</a
          >{c.noteAfter}
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
