---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import ToolCard from '../../components/ToolCard.astro';
import DeveloperToolCard from '../../components/DeveloperToolCard.astro';
import CategoryCard from '../../components/CategoryCard.astro';
import { featuredTools, developerTools } from '../../data/tools';
import {
  getLangFromUrl,
  useTranslations,
  localizePath,
  getStaticLangPaths,
} from '../../i18n/ui';

export const getStaticPaths = getStaticLangPaths;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const home = t.home;
const toolsHref = localizePath('/tools', lang);
const contactHref = localizePath('/contact', lang);
---

<BaseLayout>
  <Hero />

  {/* --- Featured Tools --- */}
  <section class="py-16 sm:py-20">
    <div class="aw-container">
      <div class="flex flex-wrap items-end justify-between gap-4">
        <SectionHeading
          eyebrow={home.featured.eyebrow}
          title={home.featured.title}
          description={home.featured.description}
        />
        <a
          href={toolsHref}
          class="hidden items-center gap-1.5 text-sm font-semibold text-navy transition-colors hover:text-gold sm:inline-flex"
        >
          {t.actions.viewAllTools}
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
        </a>
      </div>

      <div class="mt-10 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {featuredTools.map((tool) => <ToolCard tool={tool} />)}
      </div>

      <div class="mt-8 sm:hidden">
        <a href={toolsHref} class="btn-secondary w-full">{t.actions.viewAllTools}</a>
      </div>
    </div>
  </section>

  {/* --- Developer Products --- */}
  {
    developerTools.length > 0 && (
      <section id="products" class="border-t border-soft-gray py-16 sm:py-20">
        <div class="aw-container">
          <SectionHeading
            eyebrow={home.products.eyebrow}
            title={home.products.title}
            description={home.products.description}
          />
          <div class="mx-auto mt-10 max-w-3xl space-y-5">
            {developerTools.map((tool) => (
              <DeveloperToolCard tool={tool} />
            ))}
          </div>
        </div>
      </section>
    )
  }

  {/* --- Categories --- */}
  <section class="border-y border-soft-gray bg-white py-16 sm:py-20">
    <div class="aw-container">
      <SectionHeading
        eyebrow={home.categoriesSection.eyebrow}
        title={home.categoriesSection.title}
        align="center"
      />
      <div class="mx-auto mt-10 grid max-w-5xl grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {home.categories.map((c) => <CategoryCard {...c} />)}
      </div>
    </div>
  </section>

  {/* --- Concept --- */}
  <section class="py-16 sm:py-20">
    <div class="aw-container">
      <div class="grid items-start gap-10 lg:grid-cols-[0.85fr_1fr] lg:gap-16">
        <SectionHeading
          eyebrow={home.concept.eyebrow}
          title={home.concept.title}
        />
        <div>
          <ul class="space-y-4">
            {
              home.concept.points.map((p) => (
                <li class="flex items-start gap-3">
                  <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-gold" aria-hidden="true" />
                  <p class="text-base leading-8 text-charcoal">
                    <span class="font-semibold text-navy">{p.lead}</span>
                    {p.body}
                  </p>
                </li>
              ))
            }
          </ul>
          <p class="mt-7 border-l-2 border-gold/40 pl-5 text-base leading-8 text-charcoal">
            {home.concept.quote}
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* --- About / Technology --- */}
  <section class="border-y border-soft-gray bg-white py-16 sm:py-20">
    <div class="aw-container">
      <div class="mx-auto max-w-3xl">
        <SectionHeading
          eyebrow={home.approach.eyebrow}
          title={home.approach.title}
        />
        <div class="mt-6 space-y-5 text-base leading-8 text-charcoal">
          {home.approach.body.map((p) => <p>{p}</p>)}
        </div>
      </div>
    </div>
  </section>

  {/* --- Closing CTA --- */}
  <section class="py-16 sm:py-20">
    <div class="aw-container">
      <div
        class="relative overflow-hidden rounded-3xl border border-soft-gray bg-gradient-to-br from-cream to-background px-6 py-12 text-center sm:px-12 sm:py-16"
      >
        <div class="pointer-events-none absolute -right-10 -top-10 h-48 w-48 rounded-full bg-gold/10 blur-2xl" aria-hidden="true"></div>
        <h2 class="font-serif text-2xl font-bold tracking-tight text-navy sm:text-3xl">
          {home.cta.title}
        </h2>
        <p class="mx-auto mt-4 max-w-xl text-base leading-8 text-charcoal">
          {home.cta.body}
        </p>
        <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
          <a href={toolsHref} class="btn-primary w-full sm:w-auto">{t.actions.viewTools}</a>
          <a href={contactHref} class="btn-secondary w-full sm:w-auto">{t.actions.contact}</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
