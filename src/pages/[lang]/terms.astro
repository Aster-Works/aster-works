---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import { SITE } from '../../consts';
import {
  getLangFromUrl,
  useTranslations,
  localizePath,
  getStaticLangPaths,
} from '../../i18n/ui';

export const getStaticPaths = getStaticLangPaths;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const tm = t.termsPage;
const contactHref = localizePath('/contact', lang);
const pageDesc = `${SITE.name} — ${tm.headerTitle}`;
---

<BaseLayout title={tm.pageTitle} description={pageDesc}>
  <PageHeader eyebrow={tm.eyebrow} title={tm.headerTitle} />

  <section class="py-14 sm:py-18">
    <div class="aw-prose-container">
      <p class="text-sm text-charcoal/60">{tm.updatedLabel}{tm.updated}</p>

      <div class="aw-doc mt-8">
        <p>{tm.intro}</p>

        {
          tm.sections.map((section) => (
            <>
              <h2>{section.heading}</h2>
              {section.body.map((para) => (
                <p>{para}</p>
              ))}
              {section.list.length > 0 && (
                <ul>
                  {section.list.map((li) => (
                    <li>{li}</li>
                  ))}
                </ul>
              )}
            </>
          ))
        }

        <h2>{tm.contactHeading}</h2>
        <p>
          {tm.contactBefore}<a href={contactHref}>{tm.contactLink}</a>{tm.contactAfter}
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
