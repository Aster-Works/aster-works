---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import {
  getLangFromUrl,
  useTranslations,
  localizePath,
  getStaticLangPaths,
} from '../../i18n/ui';

export const getStaticPaths = getStaticLangPaths;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const a = t.aboutPage;
const toolsHref = localizePath('/tools', lang);
const contactHref = localizePath('/contact', lang);
---

<BaseLayout title={a.pageTitle} description={a.description}>
  <PageHeader eyebrow={a.eyebrow} title={a.headerTitle} lead={a.description} />

  {/* イントロ */}
  <section class="py-14 sm:py-18">
    <div class="aw-prose-container">
      <div class="space-y-6 text-base leading-8 text-charcoal">
        <p>{a.intro[0]}</p>
        <p class="font-serif text-lg leading-9 text-navy">{a.intro[1]}</p>
        <p>{a.intro[2]}</p>
      </div>
    </div>
  </section>

  {/* 大切にしている価値 */}
  <section class="border-y border-soft-gray bg-white py-14 sm:py-18">
    <div class="aw-container">
      <h2 class="font-serif text-2xl font-bold tracking-tight text-navy">
        {a.valuesHeading}
      </h2>
      <div class="mt-8 grid grid-cols-1 gap-5 sm:grid-cols-3">
        {
          a.values.map((v, i) => (
            <div class="aw-card flex h-full flex-col">
              <span class="font-serif text-sm font-bold text-gold">
                0{i + 1}
              </span>
              <h3 class="mt-2 font-serif text-lg font-bold text-navy">
                {v.title}
              </h3>
              <p class="mt-2 text-sm leading-7 text-charcoal">{v.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  {/* どんなツールをつくるか */}
  <section class="py-14 sm:py-18">
    <div class="aw-prose-container">
      <h2 class="font-serif text-2xl font-bold tracking-tight text-navy">
        {a.makeHeading}
      </h2>
      <div class="mt-5 space-y-5 text-base leading-8 text-charcoal">
        {a.makeBody.map((p) => <p>{p}</p>)}
      </div>
      <a
        href={toolsHref}
        class="mt-6 inline-flex items-center gap-1.5 text-sm font-semibold text-navy transition-colors hover:text-gold"
      >
        {a.makeLink}
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
      </a>
    </div>
  </section>

  {/* 技術とAIについて（控えめに） */}
  <section class="border-y border-soft-gray bg-white py-14 sm:py-18">
    <div class="aw-prose-container">
      <h2 class="font-serif text-2xl font-bold tracking-tight text-navy">
        {a.techHeading}
      </h2>
      <div class="mt-5 space-y-5 text-base leading-8 text-charcoal">
        {a.techBody.map((p) => <p>{p}</p>)}
      </div>
    </div>
  </section>

  {/* これから */}
  <section class="py-14 sm:py-18">
    <div class="aw-prose-container text-center">
      <h2 class="font-serif text-2xl font-bold tracking-tight text-navy">
        {a.futureHeading}
      </h2>
      <p class="mx-auto mt-5 max-w-xl text-base leading-8 text-charcoal">
        {a.futureBody}
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a href={toolsHref} class="btn-primary w-full sm:w-auto">{t.actions.viewTools}</a>
        <a href={contactHref} class="btn-secondary w-full sm:w-auto">{t.actions.contact}</a>
      </div>
    </div>
  </section>
</BaseLayout>
