---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import { SITE } from '../../consts';
import {
  getLangFromUrl,
  useTranslations,
  localizePath,
  getStaticLangPaths,
} from '../../i18n/ui';

export const getStaticPaths = getStaticLangPaths;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const p = t.privacyPage;
const contactHref = localizePath('/contact', lang);
const pageDesc = `${SITE.name} — ${p.headerTitle}`;
---

<BaseLayout title={p.pageTitle} description={pageDesc}>
  <PageHeader eyebrow={p.eyebrow} title={p.headerTitle} />

  <section class="py-14 sm:py-18">
    <div class="aw-prose-container">
      <p class="text-sm text-charcoal/60">{p.updatedLabel}{p.updated}</p>

      <div class="aw-doc mt-8">
        <p>{p.intro}</p>

        {
          p.sections.map((section) => (
            <>
              <h2>{section.heading}</h2>
              {section.body.map((para) => (
                <p>{para}</p>
              ))}
            </>
          ))
        }

        <h2>{p.contactHeading}</h2>
        <p>
          {p.contactBefore}<a href={contactHref}>{p.contactLink}</a>{p.contactAfter}
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
