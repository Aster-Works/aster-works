---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import { SITE } from '../consts';

const pageDesc = `${SITE.name} の特定商取引法に基づく表記です。`;
const updated = '2026年6月10日';

// ★ 実際の情報に置き換えてください。
// 個人事業主の場合、住所・電話番号は「請求があったら遅滞なく開示します」
// という記載で省略できます（特定商取引法の運用ガイドラインに基づく扱い）。
const items: { label: string; value: string }[] = [
  { label: '販売事業者', value: 'Aster Works（屋号）' },
  { label: '運営責任者', value: '高石 啓明' },
  {
    label: '所在地',
    value:
      '請求があったら遅滞なく開示します（個人事業主のため、ご請求はお問い合わせフォームよりお願いいたします）',
  },
  {
    label: '電話番号',
    value:
      '請求があったら遅滞なく開示します（お問い合わせはメールにて承っております）',
  },
  { label: 'メールアドレス', value: SITE.email },
  {
    label: '販売価格',
    value: '各サービス・商品の購入ページに表示する金額（消費税込み）',
  },
  {
    label: '商品代金以外の必要料金',
    value:
      'インターネット接続に係る通信料等はお客様のご負担となります。その他の手数料が発生する場合は購入ページに明記します。',
  },
  {
    label: 'お支払い方法',
    value: 'クレジットカード決済（Stripe）',
  },
  {
    label: 'お支払い時期',
    value:
      'ご注文時にお支払いが確定します。サブスクリプションの場合は、各更新日に自動決済されます。',
  },
  {
    label: '商品の引き渡し時期',
    value:
      'デジタルサービスのため、決済完了後ただちにご利用いただけます。納品物のある受託業務については、契約時に定める納期によります。',
  },
  {
    label: '返品・キャンセルについて',
    value:
      'デジタルコンテンツ・サービスの性質上、決済完了後の返品・返金は原則としてお受けできません。サービスに不具合がある場合は、お問い合わせページよりご連絡ください。個別に対応いたします。サブスクリプションはいつでも解約でき、解約後は次回更新日以降の請求は発生しません。',
  },
  {
    label: '動作環境',
    value:
      '最新版の主要ブラウザ（Chrome / Safari / Edge / Firefox）でのご利用を推奨します。',
  },
];
---

<BaseLayout title="特定商取引法に基づく表記" description={pageDesc}>
  <PageHeader eyebrow="Legal" title="特定商取引法に基づく表記" />

  <section class="py-14 sm:py-18">
    <div class="aw-prose-container">
      <p class="text-sm text-charcoal/60">最終更新日：{updated}</p>

      <div class="aw-doc mt-8">
        <p>
          「特定商取引に関する法律」第11条に基づき、以下のとおり表記します。
        </p>

        <dl class="mt-8 divide-y divide-charcoal/10 border-y border-charcoal/10">
          {
            items.map((item) => (
              <div class="grid gap-1 py-5 sm:grid-cols-[12rem_1fr] sm:gap-6">
                <dt class="text-sm font-semibold text-navy">{item.label}</dt>
                <dd class="text-sm leading-7 text-charcoal/80">{item.value}</dd>
              </div>
            ))
          }
        </dl>

        <h2>お問い合わせ</h2>
        <p>
          本表記に関するお問い合わせ、および所在地・電話番号の開示のご請求は、<a
            href="/contact">お問い合わせページ</a
          >よりご連絡ください。
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
