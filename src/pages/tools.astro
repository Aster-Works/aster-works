---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import ToolCard from '../components/ToolCard.astro';
import { tools, categoryOrder } from '../data/tools';

const filters = [
  { key: 'all', label: 'すべて' },
  ...categoryOrder.map((c) => ({ key: c, label: c })),
];

const pageTitle = 'Tools';
const pageDesc =
  'Aster Works のツール一覧です。仕事・学び・暮らしを少し軽くする、シンプルな道具を少しずつ公開していきます。';
---

<BaseLayout title={pageTitle} description={pageDesc}>
  <PageHeader
    eyebrow="Tools"
    title="日々の作業を少し軽くする、シンプルなツール。"
    lead={pageDesc}
  />

  {/* フィルター + 一覧 */}
  <section class="py-12 sm:py-16">
    <div class="aw-container">
      <div class="flex flex-wrap items-center justify-between gap-4">
        <div class="flex flex-wrap gap-2" role="group" aria-label="カテゴリで絞り込み">
          {
            filters.map((f) => (
              <button
                type="button"
                data-filter={f.key}
                aria-pressed={f.key === 'all' ? 'true' : 'false'}
                class="rounded-full border border-soft-gray bg-white px-4 py-2 text-sm font-medium text-charcoal transition-colors hover:border-navy/30 hover:text-navy aria-pressed:border-navy aria-pressed:bg-navy aria-pressed:text-white"
              >
                {f.label}
              </button>
            ))
          }
        </div>
        <p class="text-sm text-charcoal/60">
          現在 {tools.length} 件（準備中を含む）
        </p>
      </div>

      <div
        id="tool-grid"
        class="mt-8 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3"
      >
        {
          tools.map((tool) => (
            <div class="tool-item" data-category={tool.category}>
              <ToolCard tool={tool} />
            </div>
          ))
        }
      </div>

      <p
        id="empty-state"
        class="mt-10 hidden rounded-2xl border border-dashed border-soft-gray bg-white px-6 py-12 text-center text-sm text-charcoal/60"
      >
        このカテゴリのツールは、ただいま準備中です。少しずつ公開していきます。
      </p>
    </div>
  </section>

  <script>
    const pills = Array.from(
      document.querySelectorAll<HTMLButtonElement>('[data-filter]')
    );
    const items = Array.from(
      document.querySelectorAll<HTMLElement>('.tool-item')
    );
    const empty = document.getElementById('empty-state');

    const apply = (key: string) => {
      let visible = 0;
      items.forEach((el) => {
        const show = key === 'all' || el.dataset.category === key;
        el.classList.toggle('hidden', !show);
        if (show) visible += 1;
      });
      pills.forEach((p) =>
        p.setAttribute('aria-pressed', String(p.dataset.filter === key))
      );
      empty?.classList.toggle('hidden', visible !== 0);
    };

    pills.forEach((p) =>
      p.addEventListener('click', () => apply(p.dataset.filter ?? 'all'))
    );
  </script>
</BaseLayout>
