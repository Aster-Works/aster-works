---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ToolCard from '../components/ToolCard.astro';
import DeveloperToolCard from '../components/DeveloperToolCard.astro';
import { consumerTools, developerTools } from '../data/tools';

const pageTitle = 'Tools';
const pageDesc =
  'Aster Works のツール一覧です。仕事・学び・暮らしを少し軽くする、シンプルな道具を少しずつ公開していきます。';
---

<BaseLayout title={pageTitle} description={pageDesc}>
  <PageHeader
    eyebrow="Tools"
    title="日々の作業を少し軽くする、シンプルなツール。"
    lead={pageDesc}
  />

  {/* ツール一覧 */}
  <section class="py-12 sm:py-16">
    <div class="aw-container">
      <div class="flex justify-end">
        <p class="text-sm text-charcoal/60">
          現在 {consumerTools.length} 件（準備中を含む）
        </p>
      </div>

      <div class="mt-6 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {consumerTools.map((tool) => <ToolCard tool={tool} />)}
      </div>
    </div>
  </section>

  {/* --- 開発者向けツール --- */}
  {
    developerTools.length > 0 && (
      <section id="developers" class="border-t border-soft-gray bg-white py-14 sm:py-20">
        <div class="aw-container">
          <SectionHeading
            eyebrow="For Developers"
            title="開発者向けツール"
            description="個人開発者・Claude Code ユーザー向けに、実際に使えるツールを公開しています。"
          />
          <div class="mx-auto mt-10 max-w-3xl space-y-5">
            {developerTools.map((tool) => (
              <DeveloperToolCard tool={tool} />
            ))}
          </div>
        </div>
      </section>
    )
  }
</BaseLayout>
