---
// =============================================================
// Hero — トップページのファーストビュー
// =============================================================
import { getLangFromUrl, useTranslations, localizePath } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const h = t.hero;
const toolsHref = localizePath('/tools', lang);
const aboutHref = localizePath('/about', lang);
---

<section class="relative overflow-hidden">
  {/* 背景：白→生成りのグラデと、ほのかなゴールドの光 */}
  <div class="pointer-events-none absolute inset-0 -z-10" aria-hidden="true">
    <div class="absolute inset-0 bg-gradient-to-b from-white via-background to-background"></div>
    <div
      class="absolute left-1/2 top-[-12%] h-[440px] w-[440px] -translate-x-1/2 rounded-full bg-gold/10 blur-3xl sm:h-[560px] sm:w-[560px]"
    >
    </div>
  </div>

  <div class="aw-container py-20 text-center sm:py-28 lg:py-32">
    <h1
      class="mx-auto max-w-3xl font-serif text-3xl font-bold leading-[1.35] tracking-tight text-navy sm:text-4xl lg:text-[2.95rem]"
    >
      {h.titleLine1}<br class="hidden sm:block" />{h.titleLine2}
    </h1>

    <p class="mx-auto mt-6 max-w-2xl text-base leading-8 text-charcoal sm:text-lg">
      {h.sub1a}<br class="hidden sm:block" />
      {h.sub1b}
    </p>
    <p class="mx-auto mt-4 max-w-xl text-sm leading-7 text-charcoal/80 sm:text-base">
      {h.sub2}
    </p>

    <div class="mt-9 flex flex-col items-center justify-center gap-3 sm:flex-row">
      <a href={toolsHref} class="btn-primary w-full sm:w-auto">{h.ctaPrimary}</a>
      <a href={aboutHref} class="btn-secondary w-full sm:w-auto">{h.ctaSecondary}</a>
    </div>
  </div>
</section>
