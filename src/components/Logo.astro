---
// =============================================================
// Logo — ブランドロゴ表示コンポーネント
//
// 画像ロゴを /public/logo/ に配置し、src/consts.ts の LOGO[variant] に
// パスを設定すると、自動的に <img> ロゴに差し替わります。
// 未設定（null）の間は、ブランドのテキストロゴ（星マーク + "Aster Works"）を
// 表示します。仕様書 §4 の「仮のプレースホルダーではなくテキストロゴ」を満たし、
// かつ後から画像へ差し替えやすい構造です。
// =============================================================
import { LOGO, SITE } from '../consts';

interface Props {
  variant?: 'horizontal' | 'stacked' | 'icon' | 'white';
  /** ルート要素に付与する追加クラス（高さ等の調整に） */
  class?: string;
}

const { variant = 'horizontal', class: className = '' } = Astro.props;

const imageSrc = LOGO[variant];
const isWhite = variant === 'white';
const isIcon = variant === 'icon';
const isStacked = variant === 'stacked';

// テキストロゴの配色
const wordColor = isWhite ? 'text-cream' : 'text-navy';
const ringStroke = isWhite ? 'rgba(244,241,234,0.75)' : '#0D1B2A';

const markSize = isStacked ? 'h-9 w-9' : 'h-7 w-7';
---

{
  imageSrc ? (
    <img
      src={imageSrc}
      alt={SITE.name}
      decoding="async"
      class:list={['block', className || 'h-8 w-auto']}
    />
  ) : (
    <span
      class:list={[
        'inline-flex items-center gap-2.5',
        isStacked && 'flex-col gap-1.5',
        className,
      ]}
      aria-label={SITE.name}
    >
      {/* 暫定ブランドマーク：外側の円弧 + 中央のゴールドの星（4方向＝十字/tを想起） */}
      <svg
        class:list={[markSize, 'shrink-0']}
        viewBox="0 0 32 32"
        fill="none"
        aria-hidden="true"
      >
        <circle
          cx="16"
          cy="16"
          r="12.4"
          fill="none"
          stroke={ringStroke}
          stroke-width="1.4"
        />
        <path
          d="M16 8C16.4 13.6 18.4 15.6 24 16C18.4 16.4 16.4 18.4 16 24C15.6 18.4 13.6 16.4 8 16C13.6 15.6 15.6 13.6 16 8Z"
          fill="#D4A24C"
        />
      </svg>
      {!isIcon && (
        <span
          class:list={[
            'font-serif font-semibold tracking-tight',
            isStacked ? 'text-base' : 'text-lg',
            wordColor,
          ]}
        >
          Aster Works
        </span>
      )}
    </span>
  )
}
