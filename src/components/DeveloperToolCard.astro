---
// =============================================================
// DeveloperToolCard — 開発者向けプロダクト（npm 公開ツール等）のカード
// 消費者向け ToolCard より情報量を増やし、インストールコマンド・要点・
// npm / GitHub へのリンクを表示する。
// =============================================================
import type { Tool } from '../data/tools';

interface Props {
  tool: Tool;
}

const { tool } = Astro.props;
---

<article
  class="aw-card aw-card-hover relative flex h-full flex-col overflow-hidden"
>
  {/* 左上の柔らかいアクセント */}
  <div
    class="pointer-events-none absolute -left-16 -top-16 h-40 w-40 rounded-full bg-gold/10 blur-2xl"
    aria-hidden="true"
  >
  </div>

  <div class="flex flex-wrap items-center gap-2">
    <span class="aw-badge bg-gold-soft text-charcoal/80">開発ツール</span>
    <span class="aw-badge bg-navy text-white">公開中</span>
    <span class="aw-badge border border-soft-gray text-charcoal/55">npm</span>
  </div>

  <h3 class="mt-4 font-serif text-xl font-bold text-navy sm:text-2xl">
    {tool.title}
  </h3>
  {
    tool.tagline && (
      <p class="mt-1 font-serif text-base text-gold">{tool.tagline}</p>
    )
  }
  <p class="mt-3 text-sm leading-7 text-charcoal">{tool.description}</p>

  {/* インストール / 実行コマンド */}
  {
    tool.install && (
      <div class="mt-5 flex items-center justify-between gap-3 rounded-xl bg-navy px-4 py-3">
        <code class="overflow-x-auto whitespace-nowrap font-mono text-xs text-cream sm:text-sm">
          <span class="select-none text-gold">$ </span>
          {tool.install}
        </code>
        <button
          type="button"
          data-copy={tool.install}
          class="shrink-0 rounded-md border border-white/15 px-2 py-1 text-[11px] font-medium text-white/80 transition-colors hover:bg-white/10 hover:text-white"
          aria-label="コマンドをコピー"
        >
          コピー
        </button>
      </div>
    )
  }

  {/* 要点 */}
  {
    tool.highlights && tool.highlights.length > 0 && (
      <ul class="mt-5 grid gap-x-6 gap-y-2.5 sm:grid-cols-2">
        {tool.highlights.map((h) => (
          <li class="flex items-start gap-2.5 text-sm leading-7 text-charcoal">
            <svg
              class="mt-1.5 h-3.5 w-3.5 shrink-0 text-gold"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="3"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M20 6 9 17l-5-5" />
            </svg>
            <span>{h}</span>
          </li>
        ))}
      </ul>
    )
  }

  {/* リンク */}
  <div class="mt-auto flex flex-wrap gap-3 pt-6">
    {
      tool.npmUrl && (
        <a
          href={tool.npmUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary"
        >
          npm で見る
          <svg
            class="h-4 w-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M7 17 17 7M8 7h9v9" />
          </svg>
        </a>
      )
    }
    {
      tool.repoUrl && (
        <a
          href={tool.repoUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-secondary"
        >
          GitHub
          <svg
            class="h-4 w-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M7 17 17 7M8 7h9v9" />
          </svg>
        </a>
      )
    }
  </div>
</article>

<script>
  // インストールコマンドのコピー（クリップボード不可の環境では無効化）
  document
    .querySelectorAll<HTMLButtonElement>('[data-copy]')
    .forEach((btn) => {
      btn.addEventListener('click', async () => {
        const text = btn.dataset.copy ?? '';
        if (!navigator.clipboard) return;
        try {
          await navigator.clipboard.writeText(text);
          const prev = btn.textContent;
          btn.textContent = 'コピー済み';
          window.setTimeout(() => {
            btn.textContent = prev;
          }, 1500);
        } catch {
          /* 何もしない */
        }
      });
    });
</script>
