---
// =============================================================
// Footer — 全ページ共通フッター（ネイビー背景で信頼感のある締め）
// リンク・コピー・aria は表示言語（/ja/・/en/）に合わせる。
// =============================================================
import Logo from './Logo.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
import { SITE } from '../consts';
import { getLangFromUrl, useTranslations, localizePath } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const homeHref = localizePath('/', lang);

const navItems = t.nav.items.map((item) => ({
  label: item.label,
  href: localizePath(item.href, lang),
}));
const infoItems = t.footer.links.map((item) => ({
  label: item.label,
  href: localizePath(item.href, lang),
}));
---

<footer class="mt-24 bg-navy text-cream/80">
  <div class="aw-container py-14">
    <div class="flex flex-col gap-10 md:flex-row md:items-start md:justify-between">
      {/* ブランド */}
      <div class="max-w-sm">
        <a href={homeHref} class="inline-block rounded-md" aria-label={`${SITE.name} — ${t.nav.home}`}>
          <Logo variant="white" class="h-10 w-auto" />
        </a>
        <p class="mt-4 text-sm leading-7 text-cream/70">
          {t.meta.shortCopy}
        </p>
        <div class="mt-5">
          <LanguageSwitcher variant="footer" />
        </div>
      </div>

      {/* リンク群 */}
      <nav class="grid grid-cols-2 gap-x-12 gap-y-8 sm:grid-cols-2" aria-label={t.nav.footerNav}>
        <div>
          <h2 class="text-xs font-semibold uppercase tracking-[0.16em] text-gold">
            {t.footer.menuHeading}
          </h2>
          <ul class="mt-4 space-y-3 text-sm">
            {
              navItems.map((item) => (
                <li>
                  <a
                    href={item.href}
                    class="text-cream/75 transition-colors hover:text-white"
                  >
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
        <div>
          <h2 class="text-xs font-semibold uppercase tracking-[0.16em] text-gold">
            {t.footer.infoHeading}
          </h2>
          <ul class="mt-4 space-y-3 text-sm">
            {
              infoItems.map((item) => (
                <li>
                  <a
                    href={item.href}
                    class="text-cream/75 transition-colors hover:text-white"
                  >
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </nav>
    </div>

    {/* 区切り + コピーライト */}
    <div
      class="mt-12 flex flex-col gap-3 border-t border-white/10 pt-6 text-xs text-cream/60 sm:flex-row sm:items-center sm:justify-between"
    >
      <p>&copy; {SITE.copyrightYear} {SITE.name}. {t.footer.rights}</p>
      <p class="tracking-wide">{t.meta.tagline}</p>
    </div>
  </div>
</footer>
