---
// =============================================================
// Footer — 全ページ共通フッター（ネイビー背景で信頼感のある締め）
// =============================================================
import Logo from './Logo.astro';
import { NAV, FOOTER_LINKS, SITE } from '../consts';
---

<footer class="mt-24 bg-navy text-cream/80">
  <div class="aw-container py-14">
    <div class="flex flex-col gap-10 md:flex-row md:items-start md:justify-between">
      {/* ブランド */}
      <div class="max-w-sm">
        <a href="/" class="inline-block rounded-md" aria-label={`${SITE.name} — ホーム`}>
          <Logo variant="white" class="h-10 w-auto" />
        </a>
        <p class="mt-4 text-sm leading-7 text-cream/70">
          {SITE.shortCopy}
        </p>
      </div>

      {/* リンク群 */}
      <nav class="grid grid-cols-2 gap-x-12 gap-y-8 sm:grid-cols-2" aria-label="フッターナビゲーション">
        <div>
          <h2 class="text-xs font-semibold uppercase tracking-[0.16em] text-gold">
            Menu
          </h2>
          <ul class="mt-4 space-y-3 text-sm">
            {
              NAV.map((item) => (
                <li>
                  <a
                    href={item.href}
                    class="text-cream/75 transition-colors hover:text-white"
                  >
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
        <div>
          <h2 class="text-xs font-semibold uppercase tracking-[0.16em] text-gold">
            Information
          </h2>
          <ul class="mt-4 space-y-3 text-sm">
            {
              FOOTER_LINKS.map((item) => (
                <li>
                  <a
                    href={item.href}
                    class="text-cream/75 transition-colors hover:text-white"
                  >
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </nav>
    </div>

    {/* 区切り + コピーライト */}
    <div
      class="mt-12 flex flex-col gap-3 border-t border-white/10 pt-6 text-xs text-cream/60 sm:flex-row sm:items-center sm:justify-between"
    >
      <p>&copy; {SITE.copyrightYear} {SITE.name}. All rights reserved.</p>
      <p class="tracking-wide">{SITE.tagline}</p>
    </div>
  </div>
</footer>
